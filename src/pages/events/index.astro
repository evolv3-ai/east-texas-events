---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EventCard from '@/components/EventCard.astro';
import { getApprovedEvents } from '@/lib/events/data';
import { itemListJsonLd } from '@/lib/events/jsonld';

const events = getApprovedEvents();
const jsonLd = itemListJsonLd(events, Astro.site!.origin);
---
<BaseLayout title="East Texas Events | Shallow Creek" description="Source-linked East Texas events for residents, visitors, families, organizers, and answer engines.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="hero">
    <p class="eyebrow">The Piney Woods event bill</p>
    <h1>What's on in <em>East Texas</em>, checked against the source</h1>
    <p class="lede">
      Rodeos, festivals, concerts, and fairs around Longview, Kilgore, and Gladewater — every listing verified
      against its official source before it appears here, and published for humans and answer engines alike.
    </p>
    <div class="actions">
      <a class="button" href="/events/near-shallow-creek-rv-park/">Events near Shallow Creek</a>
      <a class="button secondary" href="/events.rss.xml">Subscribe via RSS</a>
    </div>
  </section>
  <section>
    <h2 class="section-title">Curated upcoming events</h2>
    <p class="freshness">{events.length} source-verified events · regenerated with every site build.</p>
    <div class="cards">
      {events.map((event) => <EventCard event={event} />)}
    </div>
  </section>
</BaseLayout>
